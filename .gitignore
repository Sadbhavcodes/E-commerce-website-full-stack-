# ──────────────────────────────────────────────
# Root .gitignore
# ──────────────────────────────────────────────

# Dependencies
node_modules/

# Environment variables — NEVER commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Build outputs
dist/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
